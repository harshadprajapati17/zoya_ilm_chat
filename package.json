    "axios": "^1.13.6",
    "csv-parser": "^3.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "openai": "^6.32.0",
    "pg": "^8.20.0",
    "prisma": "^6.19.2",
    "react": "19.2.3",
